{
  "name": "olanma-frontend",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib services store types --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:unit": "rm -rf .test-dist && tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "test:coverage": "rm -rf .test-dist coverage && tsc -p tsconfig.test.json && node --test --experimental-test-coverage --test-coverage-exclude='.test-dist/tests/**' .test-dist/tests/*.test.js",
    "test": "npm run test:unit && npm run lint && npm run typecheck"
  },
