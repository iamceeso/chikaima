    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "16.2.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.53.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
